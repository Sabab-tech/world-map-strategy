#map {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 15px;
  padding: 20px;
  background: #0b0f1a;
  color: white;
}

.country {
  background: #141b2d;
  padding: 15px;
  border-radius: 10px;
  border-left: 4px solid #4cafef;
  transition: 0.3s;
}

.country:hover {
  transform: scale(1.03);
  border-left: 4px solid #ffcc00;
}

.country h2 {
  margin: 0 0 10px 0;
  color: #4cafef;
}
